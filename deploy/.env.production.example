# Production Environment Configuration
# AdCamp AI Video Generation Pipeline

# ==========================================
# BytePlus ModelArk API Configuration
# ==========================================
ARK_API_KEY=your-production-api-key-here
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ==========================================
# Model Configuration
# ==========================================
SCRIPT_MODEL=seed-1-8-251228
VIDEO_MODEL_PRO=seedance-1-5-pro-251215
VIDEO_MODEL_FAST=seedance-1-0-pro-fast-251015

# ==========================================
# Timeouts & Polling
# ==========================================
POLL_TIMEOUT=600
POLL_INTERVAL=5

# ==========================================
# Storage
# ==========================================
OUTPUT_DIR=/app/output

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# CORS (API)
# ==========================================
CORS_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# ==========================================
# Rate Limiting (slowapi format)
# ==========================================
RATE_LIMIT=60/minute

# ==========================================
# Cost per Million Tokens (USD)
# ==========================================
# COST_PER_M_SEED18_INPUT=0.25
# COST_PER_M_SEED18_OUTPUT=2.00
# COST_PER_M_SEEDANCE_PRO=1.20
# COST_PER_M_SEEDANCE_FAST=0.70

# ==========================================
# Video Defaults
# ==========================================
# VIDEO_DURATION=8              # seconds (2-12)
# VIDEO_RESOLUTION=720p         # 480p, 720p, 1080p
# VIDEO_SOUND=true

# ==========================================
# Batch & Brief Generation
# ==========================================
# BATCH_CONCURRENCY_DEFAULT=3   # Max concurrent video generations
# BRIEF_TEMPERATURE=0.8
# BRIEF_MAX_TOKENS=256

# ==========================================
# Safety Evaluation
# ==========================================
SAFETY_ENABLED=true
# SAFETY_THRESHOLD_FLAG=0.3     # Score above this → flagged for review
# SAFETY_THRESHOLD_BLOCK=0.8    # Score above this → blocked
# SAFETY_TEMPERATURE=0.0        # Deterministic evaluation
# SAFETY_MAX_TOKENS=512

# ==========================================
# Security
# ==========================================
API_KEY=your-api-key-here       # Bearer token required on /api/* routes
MAX_UPLOAD_SIZE_MB=10

# ==========================================
# Dry-Run Mode
# ==========================================
# DRY_RUN=false                 # Set to true to simulate API calls

# ==========================================
# Storage & Persistence
# ==========================================
GCS_BUCKET=your-gcs-bucket-name
# PERSISTENCE_BACKEND=memory    # "memory" (default) or "firestore"

# ==========================================
# BytePlus VKE / Kubernetes
# ==========================================
# When deploying to VKE, these are typically set via Secrets/ConfigMaps
# See deploy/kubernetes/base/secret.yaml and deploy/kubernetes/base/deployment-api.yaml
