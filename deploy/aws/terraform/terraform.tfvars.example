# AWS Region
region = "ap-southeast-1"

# BytePlus ModelArk API Key (REQUIRED - replace with your actual key)
ark_api_key = "your-api-key-here"

# Docker images (update after pushing to your registry)
api_image       = "your-registry/adcamp-api:latest"
dashboard_image = "your-registry/adcamp-dashboard:latest"

# API Service Configuration
api_cpu           = "1024"  # 1 vCPU
api_memory        = "2048"  # 2 GB
api_desired_count = 1

# Dashboard Service Configuration
dashboard_cpu           = "256"  # 0.25 vCPU
dashboard_memory        = "512"  # 512 MB
dashboard_desired_count = 1
