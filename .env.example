# Required (unless DRY_RUN=true)
ARK_API_KEY=your_modelark_api_key_here

# --- Dry-run mode (no API key needed) ---
# DRY_RUN=true

# Optional — defaults shown (see app/config.py for full list)
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# SCRIPT_MODEL=seed-1-8-251228
# VIDEO_MODEL_PRO=seedance-1-5-pro-251215
# VIDEO_MODEL_FAST=seedance-1-0-pro-fast-251015
# VIDEO_DURATION=8
# VIDEO_RESOLUTION=720p
# VIDEO_SOUND=true
# POLL_INTERVAL=5
# POLL_TIMEOUT=300
# BATCH_CONCURRENCY_DEFAULT=3
# GCS_BUCKET=your-gcs-bucket-name
# OUTPUT_DIR=output

# --- Safety evaluation ---
# SAFETY_ENABLED=true
# SAFETY_THRESHOLD_FLAG=0.3
# SAFETY_THRESHOLD_BLOCK=0.8
# SAFETY_TEMPERATURE=0.0
# SAFETY_MAX_TOKENS=512

# --- Persistence ---
# PERSISTENCE_BACKEND=memory    # "memory" (default) or "firestore" (requires requirements-gcp.txt)

# --- Security (recommended for production) ---
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# API_KEY=your-secret-api-key
# RATE_LIMIT=60/minute
# MAX_UPLOAD_SIZE_MB=10
